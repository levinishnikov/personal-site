# Secrets only. Copy this to backend/.env (gitignored) for local dev,
# or set these in Railway → Variables for production.
#
# NEVER commit real secrets. Your PUBLIC identity (name, links, title) goes in
# backend/site.env instead, which IS committed — edit that file to make the site yours.

# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Notion sync ───────────────────────────────────────────────────────────────
# Create a Notion integration at notion.so/my-integrations.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
# The ID is the part of your database URL after the workspace name and before ?v=
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: set a secret to protect the POST /api/sync endpoint.
SYNC_SECRET=
