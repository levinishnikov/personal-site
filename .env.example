# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Site identity ─────────────────────────────────────────────────────────────
SITE_DOMAIN=https://yoursite.com

OWNER_NAME=Jane Smith
OWNER_NAME_FIRST=Jane
OWNER_NAME_LAST=Smith
OWNER_TITLE=Head of Product
OWNER_EMPLOYER=Acme Corp
OWNER_EMPLOYER_URL=https://acme.com

# One sentence shown in JSON-LD and RSS feed description.
OWNER_DESCRIPTION=Building great products at Acme Corp.

# Comma-separated list of topics you know about (used in JSON-LD knowsAbout).
OWNER_KNOWS_ABOUT=Product management,AI,Machine learning

# ── Social profiles ───────────────────────────────────────────────────────────
# Handles/usernames only — URLs are assembled automatically.
OWNER_TELEGRAM=your_telegram_handle
OWNER_LINKEDIN=your-linkedin-username
OWNER_GITHUB=your-github-username

# Wikidata Q-id — create your item at wikidata.org, then paste the ID here.
# Example: Q12345678
OWNER_WIKIDATA=

# ── Avatar ────────────────────────────────────────────────────────────────────
# Filename inside static/ — replace static/avatar.jpg with your photo.
AVATAR_FILE=avatar.jpg

# ── Hero CTA button ───────────────────────────────────────────────────────────
HERO_CTA_URL=https://t.me/your_telegram_handle
HERO_CTA_TEXT=Get in touch

# ── Page copy ─────────────────────────────────────────────────────────────────
HOME_DESCRIPTION=Personal website and blog of Jane Smith.
POSTS_DESCRIPTION=Thoughts on product, AI, and technology.

# ── Notion sync ───────────────────────────────────────────────────────────────
# Create a Notion integration at notion.so/my-integrations.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
# The ID is the part of your database URL after the workspace name and before ?v=
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: set a secret to protect the /api/sync endpoint.
SYNC_SECRET=
